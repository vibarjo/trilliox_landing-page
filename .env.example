# DAPPHO Backend Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/dappho
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dappho

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-super-secret-key-change-this-in-production

# Ethereum/Web3 Configuration
INFURA_API_KEY=your_infura_api_key
ALCHEMY_API_KEY=your_alchemy_api_key

# Smart Contract Addresses (example - update with your contract addresses)
SWAP_ROUTER_ADDRESS=0x7a250d5630b4cf539739df2c5dacb4c659f2488d
FACTORY_ADDRESS=0x1F98431c8aD98523631AE4a59f267346ea31565f
WETH_ADDRESS=0xc02aaa39b223fe8d0a0e5c4f27ead9083c756cc2

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# API Keys for External Services
COINGECKO_API_KEY=optional_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key

# Admin Settings
ADMIN_WALLET=0xYourAdminWalletAddress
ADMIN_SECRET=super-secret-admin-key
